<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>USAF PFRA Calculator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #0f172a; color: #f8fafc; }
        
        /* Smooth UI Animations */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes scaleIn { from { transform: scale(0.95); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .fade-in { animation: fadeIn 0.5s ease-out forwards; }
        .scale-in { animation: scaleIn 0.4s ease-out forwards; }
        .delay-100 { animation-delay: 100ms; }
        .delay-200 { animation-delay: 200ms; }
        
        /* Glassmorphism Panels */
        .glass-panel {
            background: linear-gradient(145deg, rgba(30, 41, 59, 0.8), rgba(15, 23, 42, 0.9));
            border: 1px solid rgba(56, 189, 248, 0.15);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(8px);
        }
        
        /* Input autofill styling override */
        input:-webkit-autofill {
            -webkit-box-shadow: 0 0 0 30px #1e293b inset !important;
            -webkit-text-fill-color: #f8fafc !important;
        }
    </style>
</head>
<body class="min-h-screen antialiased selection:bg-sky-500 selection:text-white pb-12">

    <!-- Top Navigation -->
    <header class="bg-slate-900/80 backdrop-blur-md border-b border-sky-900/40 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
            <div class="flex items-center space-x-4">
                <!-- Inline SVG Logo ensuring it never breaks -->
                <div class="w-12 h-12 text-sky-400 drop-shadow-[0_0_8px_rgba(56,189,248,0.5)]">
                    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2L15 8.5L22 9.5L17 14L18.5 21L12 17.5L5.5 21L7 14L2 9.5L9 8.5L12 2Z" />
                        <path d="M2 12C2 17.5 6.5 22 12 22C17.5 22 22 17.5 22 12" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.5"/>
                    </svg>
                </div>
                <div>
                    <h1 class="font-extrabold text-xl tracking-widest text-slate-100 uppercase">PFRA Tracker</h1>
                    <p class="text-[10px] font-bold text-sky-400 tracking-widest uppercase">Universal Standards</p>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
            <!-- Assessment Entry Form -->
            <div class="lg:col-span-4 glass-panel rounded-2xl p-6 sm:p-8 opacity-0 fade-in">
                <h2 class="text-lg font-bold text-white mb-6 flex items-center border-b border-slate-700 pb-3">
                    <i class="fa-solid fa-id-card text-sky-400 mr-3"></i> Airman Profile
                </h2>
                
                <form id="calcForm" class="space-y-5">
                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-400 mb-1.5">Name / Identifier</label>
                        <input type="text" id="name" required placeholder="e.g. Doe, J." 
                               class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-slate-100 focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-400 transition-all">
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold uppercase text-slate-400 mb-1.5">Gender</label>
                            <select id="gender" class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-slate-100 focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-400 transition-all cursor-pointer">
                                <option value="M" selected>Male</option>
                                <option value="F">Female</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase text-slate-400 mb-1.5">Age Bracket</label>
                            <select id="ageBracket" class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-slate-100 focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-400 transition-all cursor-pointer">
                                <option value="<25">Under 25</option>
                                <option value="25-29" selected>25 - 29</option>
                                <option value="30-34">30 - 34</option>
                                <option value="35-39">35 - 39</option>
                                <option value="40-44">40 - 44</option>
                                <option value="45-49">45 - 49</option>
                                <option value="50-54">50 - 54</option>
                                <option value="55-59">55 - 59</option>
                                <option value="60+">60+</option>
                            </select>
                        </div>
                    </div>

                    <h2 class="text-lg font-bold text-white mt-8 mb-4 flex items-center border-b border-slate-700 pb-3 pt-2">
                        <i class="fa-solid fa-stopwatch text-sky-400 mr-3"></i> Component Data
                    </h2>

                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-400 mb-1.5">2-Mile Run Time</label>
                        <div class="flex items-center space-x-2">
                            <input type="number" id="runMin" min="0" max="59" required placeholder="Min" class="w-full bg-slate-800 border border-slate-600 rounded-lg px-3 py-2.5 text-center font-mono focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-400">
                            <span class="text-slate-500 font-bold">:</span>
                            <input type="number" id="runSec" min="0" max="59" required placeholder="Sec" class="w-full bg-slate-800 border border-slate-600 rounded-lg px-3 py-2.5 text-center font-mono focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-400">
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold uppercase text-slate-400 mb-1.5">Push-ups</label>
                            <input type="number" id="pushups" min="0" required placeholder="1 Min" class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-center font-mono focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-400">
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase text-slate-400 mb-1.5">Sit-ups</label>
                            <input type="number" id="situps" min="0" required placeholder="1 Min" class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 text-center font-mono focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-400">
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-bold uppercase text-slate-400 mb-1.5">WHtR (Waist ÷ Height)</label>
                        <input type="number" id="whtr" min="0.30" max="0.80" step="0.01" required placeholder="e.g. 0.46" class="w-full bg-slate-800 border border-slate-600 rounded-lg px-4 py-2.5 font-mono focus:outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-400">
                    </div>

                    <button type="submit" class="w-full bg-sky-500 hover:bg-sky-400 text-slate-900 font-extrabold tracking-wide py-3.5 px-4 rounded-lg transition duration-200 shadow-[0_0_15px_rgba(56,189,248,0.3)] hover:shadow-[0_0_20px_rgba(56,189,248,0.5)] mt-4">
                        PROCESS SCORE
                    </button>
                </form>
            </div>

            <!-- Score Visualizer & Dashboard -->
            <div class="lg:col-span-8 space-y-6">
                
                <div class="glass-panel rounded-2xl p-6 sm:p-8 opacity-0 scale-in delay-100">
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
                        
                        <!-- Composite Score Display -->
                        <div class="md:col-span-4 flex flex-col items-center justify-center p-6 bg-slate-900/50 rounded-xl border border-slate-700/50">
                            <h3 class="text-xs uppercase font-bold text-slate-400 tracking-widest mb-1">Final Score</h3>
                            <span id="scoreTotal" class="text-6xl font-black text-white tabular-nums drop-shadow-md">0.0</span>
                            <div id="scoreBadge" class="mt-3 px-5 py-1.5 rounded-full text-xs font-bold tracking-widest uppercase bg-slate-800 text-slate-500 border border-slate-700 transition-all">
                                WAITING
                            </div>
                        </div>

                        <!-- Component Progress Bars -->
                        <div class="md:col-span-8 space-y-4 w-full">
                            
                            <!-- Run -->
                            <div>
                                <div class="flex justify-between items-end mb-1.5">
                                    <span class="text-xs font-bold text-slate-300 uppercase"><i class="fa-solid fa-person-running text-sky-400 w-4"></i> Run</span>
                                    <span class="text-sm font-bold text-white"><span id="ptsRun">0.0</span> <span class="text-slate-500 text-xs">/ 50</span></span>
                                </div>
                                <div class="w-full bg-slate-800 rounded-full h-2.5 overflow-hidden">
                                    <div id="barRun" class="bg-sky-400 h-2.5 rounded-full transition-all duration-1000 ease-out" style="width: 0%"></div>
                                </div>
                            </div>
                            
                            <!-- Pushups -->
                            <div>
                                <div class="flex justify-between items-end mb-1.5">
                                    <span class="text-xs font-bold text-slate-300 uppercase"><i class="fa-solid fa-hand-fist text-amber-400 w-4"></i> Push-ups</span>
                                    <span class="text-sm font-bold text-white"><span id="ptsPush">0.0</span> <span class="text-slate-500 text-xs">/ 15</span></span>
                                </div>
                                <div class="w-full bg-slate-800 rounded-full h-2.5 overflow-hidden">
                                    <div id="barPush" class="bg-amber-400 h-2.5 rounded-full transition-all duration-1000 ease-out" style="width: 0%"></div>
                                </div>
                            </div>

                            <!-- Situps -->
                            <div>
                                <div class="flex justify-between items-end mb-1.5">
                                    <span class="text-xs font-bold text-slate-300 uppercase"><i class="fa-solid fa-dumbbell text-emerald-400 w-4"></i> Sit-ups</span>
                                    <span class="text-sm font-bold text-white"><span id="ptsSit">0.0</span> <span class="text-slate-500 text-xs">/ 15</span></span>
                                </div>
                                <div class="w-full bg-slate-800 rounded-full h-2.5 overflow-hidden">
                                    <div id="barSit" class="bg-emerald-400 h-2.5 rounded-full transition-all duration-1000 ease-out" style="width: 0%"></div>
                                </div>
                            </div>

                            <!-- WHtR -->
                            <div>
                                <div class="flex justify-between items-end mb-1.5">
                                    <span class="text-xs font-bold text-slate-300 uppercase"><i class="fa-solid fa-weight-scale text-purple-400 w-4"></i> WHtR</span>
                                    <span class="text-sm font-bold text-white"><span id="ptsWhtr">0.0</span> <span class="text-slate-500 text-xs">/ 20</span></span>
                                </div>
                                <div class="w-full bg-slate-800 rounded-full h-2.5 overflow-hidden">
                                    <div id="barWhtr" class="bg-purple-400 h-2.5 rounded-full transition-all duration-1000 ease-out" style="width: 0%"></div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- History Table -->
                <div class="glass-panel rounded-2xl p-6 sm:p-8 opacity-0 scale-in delay-200">
                    <div class="flex items-center justify-between mb-5">
                        <h2 class="text-lg font-bold text-white flex items-center">
                            <i class="fa-solid fa-clock-rotate-left text-sky-400 mr-3"></i> Training Logs
                        </h2>
                        <button id="clearBtn" class="text-xs font-bold text-rose-400 hover:text-rose-300 uppercase tracking-wider transition">
                            Clear Data
                        </button>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="text-xs text-slate-400 uppercase tracking-wider border-b border-slate-700/60 bg-slate-800/30">
                                    <th class="p-3 font-semibold rounded-tl-lg">Airman</th>
                                    <th class="p-3 font-semibold text-center">Run</th>
                                    <th class="p-3 font-semibold text-center">P / S</th>
                                    <th class="p-3 font-semibold text-center">WHtR</th>
                                    <th class="p-3 font-semibold text-right rounded-tr-lg">Result</th>
                                </tr>
                            </thead>
                            <tbody id="historyBody" class="divide-y divide-slate-800 text-sm">
                                <!-- Data injects here -->
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <script>
        // Full, precise datasets sourced directly from the provided CSVs
        const preciseData = {"run": {"M": {"<25": [[805, 50.0], [824, 49.5], [843, 49.0], [862, 48.0], [881, 47.0], [900, 46.0], [919, 45.0], [938, 44.0], [957, 43.0], [976, 42.0], [995, 41.0], [1014, 40.0], [1033, 39.0], [1052, 38.5], [1071, 38.0], [1090, 37.5], [1109, 37.0], [1128, 36.5], [1147, 36.0], [1176, 35.5], [1185, 35.0]], "25-29": [[815, 50.0], [834, 49.5], [853, 49.0], [872, 48.0], [891, 47.0], [910, 46.0], [929, 45.0], [948, 44.0], [967, 43.0], [986, 42.0], [1005, 41.0], [1024, 40.0], [1043, 39.0], [1062, 38.5], [1081, 38.0], [1100, 37.5], [1119, 37.0], [1138, 36.5], [1157, 36.0], [1176, 35.5], [1195, 35.0]], "30-34": [[822, 50.0], [843, 49.5], [864, 49.0], [885, 48.0], [906, 47.0], [928, 46.0], [949, 45.0], [970, 44.0], [991, 43.0], [1012, 42.0], [1033, 41.0], [1054, 40.0], [1075, 39.0], [1096, 38.5], [1117, 38.0], [1139, 37.5], [1160, 37.0], [1181, 36.5], [1202, 36.0], [1223, 35.5], [1244, 35.0]], "35-39": [[836, 50.0], [858, 49.5], [880, 49.0], [902, 48.0], [924, 47.0], [946, 46.0], [968, 45.0], [990, 44.0], [1012, 43.0], [1034, 42.0], [1056, 41.0], [1078, 40.0], [1100, 39.0], [1122, 38.5], [1144, 38.0], [1166, 37.5], [1188, 37.0], [1210, 36.5], [1232, 36.0], [1254, 35.5], [1276, 35.0]], "40-44": [[845, 50.0], [869, 49.5], [893, 49.0], [917, 48.0], [941, 47.0], [965, 46.0], [989, 45.0], [1013, 44.0], [1037, 43.0], [1061, 42.0], [1085, 41.0], [1108, 40.0], [1132, 39.0], [1156, 38.5], [1180, 38.0], [1204, 37.5], [1228, 37.0], [1252, 36.5], [1276, 36.0], [1300, 35.5], [1324, 35.0]], "45-49": [[870, 50.0], [894, 49.5], [918, 49.0], [942, 48.0], [965, 47.0], [989, 46.0], [1013, 45.0], [1037, 44.0], [1061, 43.0], [1085, 42.0], [1109, 41.0], [1132, 40.0], [1156, 39.0], [1180, 38.5], [1204, 38.0], [1228, 37.5], [1252, 37.0], [1275, 36.5], [1299, 36.0], [1323, 35.5], [1347, 35.0]], "50-54": [[909, 50.0], [932, 49.5], [955, 49.0], [978, 48.0], [1001, 47.0], [1024, 46.0], [1047, 45.0], [1070, 44.0], [1093, 43.0], [1116, 42.0], [1140, 41.0], [1163, 40.0], [1186,