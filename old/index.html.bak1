9, 7.5], [28, 7.0], [26, 6.5], [25, 6.0], [23, 5.5], [22, 5.0], [21, 4.5], [19, 4.0], [18, 3.5], [16, 3.0], [15, 2.5]], "25-29": [[47, 15.0], [46, 14.5], [44, 14.0], [43, 13.5], [42, 13.0], [40, 12.5], [39, 12.0], [38, 11.5], [36, 11.0], [35, 10.5], [34, 10.0], [32, 9.5], [31, 9.0], [30, 8.5], [29, 8.0], [27, 7.5], [26, 7.0], [25, 6.5], [23, 6.0], [22, 5.5], [21, 5.0], [19, 4.5], [18, 4.0], [17, 3.5], [15, 3.0], [14, 2.5]], "30-34": [[44, 15.0], [42, 14.5], [41, 14.0], [40, 13.5], [39, 13.0], [37, 12.5], [36, 12.0], [35, 11.5], [34, 11.0], [32, 10.5], [31, 10.0], [30, 9.5], [29, 9.0], [27, 8.5], [26, 8.0], [25, 7.5], [24, 7.0], [22, 6.5], [21, 6.0], [20, 5.5], [19, 5.0], [17, 4.5], [16, 4.0], [15, 3.5], [14, 3.0], [12, 2.5]], "35-39": [[42, 15.0], [41, 14.5], [40, 14.0], [38, 13.5], [37, 13.0], [36, 12.5], [35, 12.0], [33, 11.5], [32, 11.0], [31, 10.5], [30, 10.0], [28, 9.5], [27, 9.0], [26, 8.5], [25, 8.0], [23, 7.5], [22, 7.0], [21, 6.5], [20, 6.0], [18, 5.5], [17, 5.0], [16, 4.5], [15, 4.0], [13, 3.5], [12, 3.0], [11, 2.5]], "40-44": [[39, 15.0], [38, 14.5], [37, 14.0], [36, 13.5], [35, 13.0], [33, 12.5], [32, 12.0], [31, 11.5], [30, 11.0], [29, 10.5], [27, 10.0], [26, 9.5], [25, 9.0], [24, 8.5], [23, 8.0], [21, 7.5], [20, 7.0], [19, 6.5], [18, 6.0], [17, 5.5], [15, 5.0], [14, 4.5], [13, 4.0], [12, 3.5], [11, 3.0], [10, 2.5]], "45-49": [[36, 15.0], [35, 14.5], [34, 14.0], [33, 13.5], [32, 13.0], [30, 12.5], [29, 12.0], [28, 11.5], [27, 11.0], [26, 10.5], [25, 10.0], [24, 9.5], [23, 9.0], [21, 8.5], [20, 8.0], [19, 7.5], [18, 7.0], [17, 6.5], [16, 6.0], [15, 5.5], [14, 5.0], [12, 4.5], [11, 4.0], [10, 3.5], [9, 3.0], [8, 2.5]], "50-54": [[34, 15.0], [33, 14.5], [32, 14.0], [31, 13.5], [30, 13.0], [29, 12.5], [28, 12.0], [26, 11.5], [25, 11.0], [24, 10.5], [23, 10.0], [22, 9.5], [21, 9.0], [20, 8.5], [19, 8.0], [18, 7.5], [17, 7.0], [16, 6.5], [15, 6.0], [13, 5.5], [12, 5.0], [11, 4.5], [10, 4.0], [9, 3.5], [8, 3.0], [7, 2.5]], "55-59": [[31, 15.0], [30, 14.5], [29, 14.0], [28, 13.5], [27, 13.0], [26, 12.5], [25, 12.0], [24, 11.5], [23, 11.0], [22, 10.5], [21, 10.0], [20, 9.5], [19, 9.0], [17, 8.5], [16, 8.0], [15, 7.5], [14, 7.0], [13, 6.5], [12, 6.0], [11, 5.5], [10, 5.0], [9, 4.5], [8, 4.0], [7, 3.5], [6, 3.0], [5, 2.5]], "60+": [[28, 15.0], [27, 14.5], [26, 14.0], [25, 13.5], [24, 13.0], [23, 12.5], [22, 12.0], [21, 11.5], [20, 11.0], [19, 10.5], [18, 10.0], [17, 9.5], [16, 9.0], [15, 8.5], [14, 8.0], [13, 7.5], [12, 7.0], [11, 6.5], [10, 6.0], [9, 5.5], [8, 5.0], [7, 4.5], [6, 4.0], [5, 3.5], [4, 3.0], [3, 2.5]]}}, "whtr": [[0.49, 20], [0.5, 19], [0.51, 18], [0.52, 17], [0.53, 16], [0.54, 15], [0.55, 12.5], [0.56, 10], [0.57, 7.5], [0.58, 5], [0.59, 2.5]]};

        // Calculates exact points based on precise data mapped above
        function calculatePoints(type, val, gender, ageGroup) {
            // Check independent metrics first (WHtR)
            if (type === 'whtr') {
                for (let arr of preciseData.whtr) {
                    if (val <= arr[0]) return arr[1];
                }
                return 0; // Exceeded maximum WHtR
            }

            // Check exercise metrics exactly mapping to the proper gender and age
            if (preciseData[type] && preciseData[type][gender] && preciseData[type][gender][ageGroup]) {
                for (let arr of preciseData[type][gender][ageGroup]) {
                    // Run logic: Values must be at or below target time (in seconds)
                    if (type === 'run' && val <= arr[0]) return arr[1];
                    // Pushups/Situps logic: Values must be at or above target reps
                    if (type !== 'run' && val >= arr[0]) return arr[1];
                }
            }
            return 0; // Minimum requirements not met
        }

        document.getElementById('calcForm').addEventListener('submit', (e) => {
            e.preventDefault();

            // Extract values
            const name = document.getElementById('name').value;
            const gender = document.getElementById('gender').value;
            const ageGroup = document.getElementById('ageBracket').value;
            const runMin = parseInt(document.getElementById('runMin').value);
            const runSec = parseInt(document.getElementById('runSec').value);
            const pushups = parseInt(document.getElementById('pushups').value);
            const situps = parseInt(document.getElementById('situps').value);
            const whtr = parseFloat(document.getElementById('whtr').value);

            // Calculate exact scoring based on threshold points mapped to values
            const runTotalSec = (runMin * 60) + runSec;
            const ptsR = calculatePoints('run', runTotalSec, gender, ageGroup);
            const ptsP = calculatePoints('pushup', pushups, gender, ageGroup);
            const ptsS = calculatePoints('situp', situps, gender, ageGroup);
            const ptsW = calculatePoints('whtr', whtr, null, null);

            const total = parseFloat((ptsR + ptsP + ptsS + ptsW).toFixed(1));
            const hasZero = (ptsR === 0 || ptsP === 0 || ptsS === 0);

            let status = 'FAILED';
            let style = 'bg-rose-500/20 text-rose-400 border-rose-500/50 shadow-[0_0_10px_rgba(244,63,94,0.3)]';

            if (total >= 90.0 && !hasZero) {
                status = 'EXCELLENT';
                style = 'bg-emerald-500/20 text-emerald-400 border-emerald-500/50 shadow-[0_0_10px_rgba(16,185,129,0.3)]';
            } else if (total >= 75.0 && !hasZero) {
                status = 'SATISFACTORY';
                style = 'bg-sky-500/20 text-sky-400 border-sky-500/50 shadow-[0_0_10px_rgba(56,189,248,0.3)]';
            }

            // Update user interface
            document.getElementById('scoreTotal').innerText = total.toFixed(1);
            const badge = document.getElementById('scoreBadge');
            badge.className = `mt-3 px-6 py-2 rounded-full text-xs font-black tracking-widest uppercase border transition-all ${style}`;
            badge.innerText = status;

            const updateBar = (id, val, max) => {
                document.getElementById(`pts${id}`).innerText = val.toFixed(1);
                document.getElementById(`bar${id}`).style.width = `${Math.min((val/max)*100, 100)}%`;
            };

            updateBar('Run', ptsR, 50);
            updateBar('Push', ptsP, 15);
            updateBar('Sit', ptsS, 15);
            updateBar('Whtr', ptsW, 20);

            // Log save to localStorage
            const record = {
                name, bracket: ageGroup, gender,
                runStr: `${runMin}:${runSec.toString().padStart(2, '0')}`,
                pushups, situps, whtr: whtr.toFixed(2), total, status,
                date: new Date().toLocaleDateString()
            };

            let logs = JSON.parse(localStorage.getItem('usaf_pfra_db')) || [];
            logs.unshift(record);
            if (logs.length > 12) logs.pop();
            localStorage.setItem('usaf_pfra_db', JSON.stringify(logs));

            renderLogs();
        });

        function renderLogs() {
            const logs = JSON.parse(localStorage.getItem('usaf_pfra_db')) || [];
            const tbody = document.getElementById('historyBody');
            tbody.innerHTML = '';

            if(logs.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="p-6 text-center text-slate-500 text-xs tracking-wider">No sessions logged yet.</td></tr>`;
                return;
            }

            logs.forEach(log => {
                const color = log.status === 'FAILED' ? 'text-rose-400' : 'text-emerald-400';
                tbody.innerHTML += `
                    <tr class="hover:bg-slate-800/40 transition-colors">
                        <td class="p-3">
                            <div class="font-bold text-slate-200">${log.name}</div>
                            <div class="text-[10px] text-slate-500 uppercase">${log.date} • ${log.gender} (${log.bracket})</div>
                        </td>
                        <td class="p-3 text-center font-mono text-slate-300">${log.runStr}</td>
                        <td class="p-3 text-center font-mono text-slate-300">${log.pushups} / ${log.situps}</td>
                        <td class="p-3 text-center font-mono text-slate-300">${log.whtr}</td>
                        <td class="p-3 text-right">
                            <div class="font-black ${color} text-base">${log.total.toFixed(1)}</div>
                            <div class="text-[9px] font-bold text-slate-500 uppercase">${log.status}</div>
                        </td>
                    </tr>
                `;
            });
        }

        document.getElementById('clearBtn').addEventListener('click', () => {
            if(confirm("Erase all 12 saved sessions from this device?")) {
                localStorage.removeItem('usaf_pfra_db');
                renderLogs();
            }
        });

        // Setup display state on initial mount
        renderLogs();
    </script>
</body>
</html>
